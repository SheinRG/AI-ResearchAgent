# === AI Research Agent — Frontend Environment Variables ===
# NOTE: NEXT_PUBLIC_* values are inlined into the browser bundle at BUILD time.
# When deploying with Docker, pass them as build args (see frontend/Dockerfile),
# not just at runtime.

# Base URL of the backend API (no trailing slash).
# Local dev:   http://localhost:8000
# Production:  https://your-backend-host
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth client ID (optional — the Google button is hidden if unset).
# Must match GOOGLE_CLIENT_ID configured on the backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
