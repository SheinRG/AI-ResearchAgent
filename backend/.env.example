# === AI Research Agent — Environment Variables ===

# --- Groq (Cloud LLM) ---
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
# Fast model used for planning + reflection (structured JSON tasks).
GROQ_MODEL=llama-3.1-8b-instant
# Stronger model used for the final synthesized answer. Set this equal to
# GROQ_MODEL to trade answer quality for lower cost/latency.
GROQ_SYNTH_MODEL=llama-3.3-70b-versatile

# --- Research tuning (optional; sensible defaults in config.py) ---
# Re-ranker: ms-marco-MiniLM-L-12-v2 (better) or ms-marco-TinyBERT-L-2-v2 (fastest)
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
# Max distinct sources surfaced to the model + UI for citation
MAX_CITED_SOURCES=8
# Set >1 to enable the reflect-and-refine loop (slower, more thorough)
MAX_ITERATIONS=1

# --- Serper (Search API) ---
# Get your free API key at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# --- Tavily (search + read API) ---
# Get a free key at https://app.tavily.com (1,000 credits/month, no card).
# When set, the researcher uses Tavily's one-call search+content instead of
# Serper search + scraping (faster + reliable content on JS-heavy sites).
# Leave blank or set USE_TAVILY_SEARCH=false to use the Serper+scrape path.
TAVILY_API_KEY=
USE_TAVILY_SEARCH=true

# --- Auth ---
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-in-production-use-a-random-string
# Get Google OAuth credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id-here

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/research_agent

# --- Rate Limiting ---
RATE_LIMIT_PER_HOUR=30
