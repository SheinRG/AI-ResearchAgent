# === AI Research Agent — Environment Variables ===

# --- Groq (Cloud LLM) ---
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- Serper (Search API) ---
# Get your free API key at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# --- Auth ---
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-in-production-use-a-random-string
# Get Google OAuth credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id-here

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/research_agent

# --- Rate Limiting ---
RATE_LIMIT_PER_HOUR=30
