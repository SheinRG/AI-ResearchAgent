# === AI Research Agent — Root Environment Variables ===
# These are passed to Docker Compose services

# --- Groq (Cloud LLM) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- Serper (Search API) ---
SERPER_API_KEY=your-serper-api-key-here

# --- Auth ---
AUTH_SECRET=change-me-in-production-use-a-random-string
GOOGLE_CLIENT_ID=your-google-client-id-here

# --- Observability (optional) ---
# Leave the DSNs blank to disable error tracking. Set them to Sentry DSNs to enable.
ENVIRONMENT=development
SENTRY_DSN=                  # backend (FastAPI) errors
NEXT_PUBLIC_SENTRY_DSN=      # frontend (Next.js) errors — inlined into the client bundle at build time
